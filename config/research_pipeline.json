{
  "name": "research",
  "artifacts": {
    "okx_candles": "data/raw/okx/candles/BTC-USDT-SWAP/1m/BTC-USDT-SWAP_1m.jsonl",
    "bitget_funding": "data/raw/bitget/derivatives/BTCUSDT/funding/BTCUSDT_funding.jsonl",
    "bitget_basis": "data/raw/bitget/derivatives/BTCUSDT/basis_proxy/5m/BTCUSDT_basis_proxy_5m.jsonl",
    "market_state_dataset": "data/intermediate/market_state/crypto_market_state_dataset_v1.jsonl",
    "ma_utility_dataset": "data/intermediate/parameter_utility/ma_parameter_utility_dataset_v1.jsonl",
    "donchian_utility_dataset": "data/intermediate/parameter_utility/donchian_parameter_utility_dataset_v1.jsonl",
    "bollinger_utility_dataset": "data/intermediate/parameter_utility/bollinger_parameter_utility_dataset_v1.jsonl",
    "strategy_utility_dataset": "data/intermediate/parameter_utility/strategy_parameter_utility_dataset_v1.jsonl",
    "family_market_state_report_json": "reports/research/family_market_state_report.json",
    "family_market_state_report_md": "reports/research/family_market_state_report.md",
    "unsupervised_baseline": "data/derived/unsupervised_market_state_baseline_v1.json",
    "labels_jsonl": "data/intermediate/market_state/unsupervised_market_state_labels_v1.jsonl",
    "labels_summary": "data/derived/unsupervised_market_state_labels_summary_v1.json",
    "unsupervised_evaluation": "data/derived/unsupervised_market_state_evaluation_v1.json",
    "market_discovery_payload": "data/derived/market_discovery_btc_v1.json"
  },
  "steps": [
    {
      "name": "fetch_okx_candles",
      "command": [
        "./.venv/bin/python",
        "scripts/data/fetch_okx_history_candles.py",
        "--inst-id",
        "BTC-USDT-SWAP",
        "--bar",
        "1m",
        "--resume"
      ],
      "outputs": [
        "{okx_candles}"
      ]
    },
    {
      "name": "fetch_bitget_context",
      "command": [
        "./.venv/bin/python",
        "scripts/data/fetch_bitget_derivatives_context.py",
        "--symbol",
        "BTCUSDT",
        "--product-type",
        "USDT-FUTURES",
        "--kind",
        "all",
        "--timeframe",
        "5m",
        "--resume"
      ],
      "outputs": [
        "{bitget_funding}",
        "{bitget_basis}"
      ]
    },
    {
      "name": "build_market_state_dataset",
      "command": [
        "./.venv/bin/python",
        "src/runners/build_crypto_market_state_dataset.py",
        "--okx-candles",
        "{okx_candles}",
        "--bitget-funding",
        "{bitget_funding}",
        "--bitget-basis",
        "{bitget_basis}",
        "--out",
        "{market_state_dataset}",
        "--resume"
      ],
      "inputs": [
        "{okx_candles}",
        "{bitget_funding}",
        "{bitget_basis}"
      ],
      "outputs": [
        "{market_state_dataset}"
      ],
      "skip_if_outputs_fresh": true
    },
    {
      "name": "build_ma_utility_dataset",
      "command": [
        "./.venv/bin/python",
        "src/runners/build_ma_parameter_utility_dataset.py",
        "--candles",
        "{okx_candles}",
        "--out",
        "{ma_utility_dataset}"
      ],
      "inputs": [
        "{okx_candles}"
      ],
      "outputs": [
        "{ma_utility_dataset}"
      ],
      "skip_if_outputs_fresh": true
    },
    {
      "name": "build_donchian_utility_dataset",
      "command": [
        "./.venv/bin/python",
        "src/runners/build_donchian_parameter_utility_dataset.py",
        "--candles",
        "{okx_candles}",
        "--out",
        "{donchian_utility_dataset}"
      ],
      "inputs": [
        "{okx_candles}"
      ],
      "outputs": [
        "{donchian_utility_dataset}"
      ],
      "skip_if_outputs_fresh": true
    },
    {
      "name": "build_bollinger_utility_dataset",
      "command": [
        "./.venv/bin/python",
        "src/runners/build_bollinger_parameter_utility_dataset.py",
        "--candles",
        "{okx_candles}",
        "--out",
        "{bollinger_utility_dataset}"
      ],
      "inputs": [
        "{okx_candles}"
      ],
      "outputs": [
        "{bollinger_utility_dataset}"
      ],
      "skip_if_outputs_fresh": true
    },
    {
      "name": "build_strategy_utility_dataset",
      "command": [
        "./.venv/bin/python",
        "src/runners/build_strategy_parameter_utility_dataset.py",
        "--input",
        "{ma_utility_dataset}",
        "--input",
        "{donchian_utility_dataset}",
        "--input",
        "{bollinger_utility_dataset}",
        "--out",
        "{strategy_utility_dataset}"
      ],
      "inputs": [
        "{ma_utility_dataset}",
        "{donchian_utility_dataset}",
        "{bollinger_utility_dataset}"
      ],
      "outputs": [
        "{strategy_utility_dataset}"
      ],
      "skip_if_outputs_fresh": true
    },
    {
      "name": "build_family_market_state_report",
      "command": [
        "./.venv/bin/python",
        "src/runners/build_family_market_state_report.py",
        "--state-dataset",
        "{market_state_dataset}",
        "--utility-dataset",
        "{strategy_utility_dataset}",
        "--output-json",
        "{family_market_state_report_json}",
        "--output-md",
        "{family_market_state_report_md}"
      ],
      "inputs": [
        "{market_state_dataset}",
        "{strategy_utility_dataset}"
      ],
      "outputs": [
        "{family_market_state_report_json}",
        "{family_market_state_report_md}"
      ],
      "skip_if_outputs_fresh": true
    },
    {
      "name": "build_unsupervised_baseline",
      "command": [
        "./.venv/bin/python",
        "src/runners/build_unsupervised_market_state_baseline.py",
        "--state-dataset",
        "{market_state_dataset}",
        "--utility-dataset",
        "{ma_utility_dataset}",
        "--out",
        "{unsupervised_baseline}"
      ],
      "inputs": [
        "{market_state_dataset}",
        "{ma_utility_dataset}"
      ],
      "outputs": [
        "{unsupervised_baseline}"
      ],
      "skip_if_outputs_fresh": true
    },
    {
      "name": "build_timestamp_labels",
      "command": [
        "./.venv/bin/python",
        "src/runners/build_unsupervised_timestamp_labels.py",
        "--state-dataset",
        "{market_state_dataset}",
        "--out-jsonl",
        "{labels_jsonl}",
        "--out-json",
        "{labels_summary}",
        "--symbol",
        "BTC-USDT-SWAP",
        "--batch-size",
        "50000"
      ],
      "inputs": [
        "{market_state_dataset}",
        "{unsupervised_baseline}"
      ],
      "outputs": [
        "{labels_jsonl}",
        "{labels_summary}"
      ],
      "skip_if_outputs_fresh": true
    },
    {
      "name": "evaluate_labels",
      "command": [
        "./.venv/bin/python",
        "src/runners/evaluate_unsupervised_labels.py",
        "--labels",
        "{labels_jsonl}",
        "--utility-dataset",
        "{ma_utility_dataset}",
        "--out",
        "{unsupervised_evaluation}",
        "--symbol",
        "BTC-USDT-SWAP"
      ],
      "inputs": [
        "{labels_jsonl}",
        "{ma_utility_dataset}"
      ],
      "outputs": [
        "{unsupervised_evaluation}"
      ],
      "skip_if_outputs_fresh": true
    },
    {
      "name": "build_market_discovery_payload",
      "command": [
        "./.venv/bin/python",
        "src/runners/build_market_discovery_web_payload.py"
      ],
      "inputs": [
        "{labels_jsonl}",
        "{labels_summary}",
        "{unsupervised_baseline}"
      ],
      "outputs": [
        "{market_discovery_payload}"
      ],
      "skip_if_outputs_fresh": true
    }
  ]
}
